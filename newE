# #36 compute_similarity
# ════════════════════════════════════════════
def compute_similarity(text_a, text_b):
    try:
        from sentence_transformers import SentenceTransformer, util
        model = SentenceTransformer("all-MiniLM-L6-v2")
        ea = model.encode(text_a, convert_to_tensor=True)
        eb = model.encode(text_b, convert_to_tensor=True)
        return max(0.0, min(1.0, (float(util.pytorch_cos_sim(ea, eb).item()) + 1) / 2))
    except ImportError:
        ta = set(re.findall(r"\w+", text_a.lower()))
        tb = set(re.findall(r"\w+", text_b.lower()))
        if not ta and not tb: return 1.0
        if not ta or not tb: return 0.0
        return len(ta & tb) / len(ta | tb)


