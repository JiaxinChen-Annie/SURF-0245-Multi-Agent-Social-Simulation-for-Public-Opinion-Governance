# #35 visualize_trend
# ════════════════════════════════════════════
def visualize_trend(data, metrics, out_path, title=None):
    if "tick" not in data.columns:
        raise KeyError("data 必须有 tick 列")
    missing = [c for c in metrics if c not in data.columns]
    if missing:
        raise KeyError(f"缺少列: {missing}")

    has_label = "experiment_label" in data.columns
    n = len(metrics)
    fig, axes = plt.subplots(n, 1, figsize=DEFAULT_FIG_SIZE, sharex=True, squeeze=False)
    axes = axes[:, 0]

    for i, metric in enumerate(metrics):
        ax = axes[i]
        if has_label:
            for lbl, grp in data.groupby("experiment_label"):
                grp_s = grp.sort_values("tick")
                ax.plot(grp_s["tick"], grp_s[metric], label=str(lbl), linewidth=1.5)
            ax.legend(fontsize=9)
        else:
            df_s = data.sort_values("tick")
            ax.plot(df_s["tick"], df_s[metric], color="#1f77b4", linewidth=1.5)
        ax.set_ylabel(metric, fontsize=11)
        ax.grid(True, alpha=0.3)

    axes[-1].set_xlabel("tick", fontsize=11)
    fig.suptitle(title or "仿真指标趋势", fontsize=14, fontweight="bold")
    fig.tight_layout(rect=[0, 0, 1, 0.97])

    out = Path(out_path).with_suffix(".png")
    out.parent.mkdir(parents=True, exist_ok=True)
    fig.savefig(out, dpi=150, bbox_inches="tight")
    plt.close(fig)
    return str(out.resolve())


