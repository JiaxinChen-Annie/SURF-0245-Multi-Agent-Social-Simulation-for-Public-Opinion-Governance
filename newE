# #33 parse_llm_response
# ════════════════════════════════════════════
def parse_llm_response(raw: str) -> Dict[str, Any]:
    """
    解析 LLM 响应（v2：支持 message_type、topic_id）。

    解析策略（依次尝试）：
      1. 纯 JSON
      2. Markdown ```json 代码块
      3. 正则提取第一个 {} 对象
      4. SILENT 兜底
    """
    text = raw.strip()

    for strategy in [
        lambda t: json.loads(t),
        lambda t: json.loads(m.group(1).strip())
                   if (m := re.search(r"```(?:json)?\s*\n?(.*?)\n?```", t, re.DOTALL))
                   else None,
        lambda t: json.loads(m.group(0))
                   if (m := re.search(r"\{[^{}]*\}", t)) else None,
    ]:
        try:
            data = strategy(text)
            if isinstance(data, dict):
                return _normalize(data)
        except (json.JSONDecodeError, TypeError, AttributeError):
            continue

    _LOG.warning("LLM 响应解析失败, SILENT 兜底")
    return _default()


def _normalize(data: dict) -> Dict[str, Any]:
    """校验并规范化 LLM 输出字段。"""
    out = _default()

    # action_type
    at = str(data.get("action_type", "")).upper().strip()
    try:
        out["action_type"] = ActionType[at]
    except KeyError:
        pass  # 保持 SILENT

    if "content" in data:
        out["content"] = str(data["content"])

    if "topic_id" in data:
        out["topic_id"] = str(data["topic_id"])

    # message_type
    mt = str(data.get("message_type", "")).strip().lower()
    valid_types = {"original", "forward", "paraphrase", "exaggerate", "clarification"}
    if mt in valid_types:
        out["message_type"] = mt

    if data.get("target_id") is not None:
        out["target_id"] = int(data["target_id"])

    return out


def _default() -> Dict[str, Any]:
    return {
        "action_type": ActionType.SILENT,
        "content": "",
        "topic_id": "",
        "message_type": "original",
        "target_id": None,
    }


