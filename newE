# #32 build_prompt
# ════════════════════════════════════════════
def build_prompt(belief, memory, env_info) -> str:
    """
    组装 LLM prompt。

    参数：
      belief   : BeliefSystem（含身份/心理/观点/情绪）
      memory   : List[MemoryRecord]
      env_info : Dict（由 B._update_beliefs 组装，含 group_type、nickname、
                 recent_messages、mentions、topic_heat、topic_negative 等）
    """
    idn, psy, emo = belief.identity, belief.psychology, belief.emotion

    # ── 身份 ──
    identity_str = (f"昵称: {idn.nickname}\n"
                    f"角色类型: {idn.agent_type.name}\n"
                    f"群类型: {idn.group_type.name}\n"
                    f"角色描述: {idn.role_desc}\n"
                    f"初始立场: {idn.stance_prior:.2f}\n")

    # ── 心理 ──
    p = psy.personality
    psych_str = (f"人格: O={p.openness:.2f} C={p.conscientiousness:.2f} "
                 f"E={p.extraversion:.2f} A={p.agreeableness:.2f} "
                 f"N={p.neuroticism:.2f}\n"
                 f"风险规避: {psy.risk_aversion:.2f}\n")

    # ── 情绪 ──
    emotion_str = f"情绪: valence={emo.valence:.2f}, arousal={emo.arousal:.2f}\n"

    # ── 观点 ──
    views = []
    for tid, ob in belief.opinions.items():
        views.append(f"  - 话题 {tid}: 立场={ob.opinion_value:.2f}, 置信={ob.confidence:.2f}")
    opinion_str = "当前观点:\n" + "\n".join(views) if views else "当前观点: (无)"

    # ── 记忆 ──
    mem_lines = []
    for rec in memory[-5:]:
        info = rec.info
        mem_lines.append(
            f"  [tick={rec.tick}] {info.source_nickname} "
            f"[{info.message_type}]: \"{info.content[:60]}\" "
            f"(负面={info.negative_score:.2f}, 失真={info.distortion_level:.2f})")
    mem_str = "近期记忆:\n" + "\n".join(mem_lines) if mem_lines else "近期记忆: (空)"

    # ── 环境感知（Dict） ──
    env_lines = [f"群类型: {env_info.get('group_type', '?')}"]
    env_lines.append(f"干预系数 β: {env_info.get('beta', 0):.2f}")
    env_lines.append(f"当前 tick: {env_info.get('tick', 0)}")
    nick = env_info.get("nickname", "")
    if nick:
        env_lines.append(f"你的昵称: {nick}")

    topic_heat = env_info.get("topic_heat", {})
    if topic_heat:
        heats = ", ".join(f"{k}(热度={v:.2f})" for k, v in topic_heat.items())
        env_lines.append(f"话题热度: {heats}")

    topic_neg = env_info.get("topic_negative", {})
    if topic_neg:
        negs = ", ".join(f"{k}(负面={v:.2f})" for k, v in topic_neg.items())
        env_lines.append(f"话题负面程度: {negs}")

    msgs = env_info.get("recent_messages", [])
    if msgs:
        env_lines.append("最近消息:")
        for m in msgs[-5:]:
            env_lines.append(f"  {m}")

    mentions = env_info.get("mentions", [])
    if mentions:
        env_lines.append(f"提到你 ({len(mentions)} 条):")
        for m in mentions[:3]:
            env_lines.append(f"  {m}")

    env_str = "环境感知:\n" + "\n".join(env_lines)

    # ── 行动指令 ──
    action_choices = "SEND_MESSAGE|REPLY|FORWARD|SILENT"
    msg_choices = "original|forward|paraphrase|exaggerate|clarification"

    return (
        f"你是在微信群中讨论的普通大学生。请根据你的角色、心理、观点和当前群聊环境决定下一步行动。\n\n"
        f"### 角色\n{identity_str}\n"
        f"### 心理\n{psych_str}\n"
        f"### 情绪\n{emotion_str}\n"
        f"### {opinion_str}\n\n"
        f"### {mem_str}\n\n"
        f"### {env_str}\n\n"
        f"### 行动指令\n"
        f"输出 JSON，字段如下：\n"
        f"  action_type: {action_choices}  (行动类型)\n"
        f"  content: 你要发送的内容 (字符串)\n"
        f"  topic_id: 话题标识 (字符串)\n"
        f"  message_type: {msg_choices}  (消息类型)\n"
        f"  target_id: 回复目标 agent_id (数字或 null)\n\n"
        f"只输出 JSON，不要其他文字。\n"
    )


