"""
多智能体舆情仿真 — 自定义类型定义（微信群聊场景 v2）
数据契约，所有模块共享

角色：ORDINARY / ACTIVE / RATIONAL / CONTROLLER
群类型：DORM / CLASS / MAJOR / CAMPUS
消息类型：original / forward / paraphrase / exaggerate / clarification
"""

from enum import IntEnum
from typing import Dict, List, Optional, Any

# ====================================================================
# 枚举定义
# ====================================================================

class AgentType(IntEnum):
    ORDINARY = 0      # 普通群员（多数沉默，偶尔附和/提问）
    ACTIVE = 1        # 活跃讨论者（乐于转发、分享信息）
    RATIONAL = 2      # 理性讨论者（质疑、查证、分析逻辑）
    CONTROLLER = 3    # 管理者（提醒、澄清、禁言、公告）


class GroupType(IntEnum):
    DORM = 0          # 宿舍群（管理强度很弱，低曝光）
    CLASS = 1         # 班级群（管理强度中弱）
    MAJOR = 2         # 专业群（管理强度中）
    CAMPUS = 3        # 校园群（管理强度强，高曝光）


# 干预衰减率 βₖ
# 约束：β₁ < β₂ < β₃ < β₄
GROUP_BETA = {
    GroupType.DORM: 0.05,      # β₁
    GroupType.CLASS: 0.12,     # β₂
    GroupType.MAJOR: 0.20,     # β₃
    GroupType.CAMPUS: 0.30,    # β₄
}


class ActionType(IntEnum):
    SEND_MESSAGE = 0  # 发新消息
    REPLY = 1         # 回复他人消息
    FORWARD = 2       # 转发消息
    SILENT = 3        # 沉默


# 消息类型（5类，与 ActionType 独立）
class MessageType:
    ORIGINAL = "original"
    FORWARD = "forward"
    PARAPHRASE = "paraphrase"
    EXAGGERATE = "exaggerate"
    CLARIFICATION = "clarification"


# ====================================================================
# 数据类
# ====================================================================

class Personality:
    """五因素人格"""
    def __init__(self, openness=0.5, conscientiousness=0.5, extraversion=0.5,
                 agreeableness=0.5, neuroticism=0.5):
        self.openness = max(0.0, min(1.0, openness))
        self.conscientiousness = max(0.0, min(1.0, conscientiousness))
        self.extraversion = max(0.0, min(1.0, extraversion))
        self.agreeableness = max(0.0, min(1.0, agreeableness))
        self.neuroticism = max(0.0, min(1.0, neuroticism))

    def to_dict(self):
        return {k: getattr(self, k) for k in
                ["openness", "conscientiousness", "extraversion",
                 "agreeableness", "neuroticism"]}

    @classmethod
    def from_dict(cls, d):
        return cls(**{k: float(v) for k, v in d.items()})


class EmotionState:
    """情绪状态"""
    def __init__(self, valence=0.0, arousal=0.5):
        self.valence = max(-1.0, min(1.0, valence))
        self.arousal = max(0.0, min(1.0, arousal))

    def to_dict(self):
        return {"valence": self.valence, "arousal": self.arousal}

    @classmethod
    def from_dict(cls, d):
        return cls(valence=float(d.get("valence", 0)),
                   arousal=float(d.get("arousal", 0.5)))


class IdentityBelief:
    """身份信念（v2：加入 group_type、nickname）"""
    def __init__(self, agent_type=AgentType.ORDINARY,
                 group_type=GroupType.CLASS,
                 nickname="", role_desc="", stance_prior=0.0):
        self.agent_type = agent_type
        self.group_type = group_type
        self.nickname = nickname
        self.role_desc = role_desc
        self.stance_prior = max(-1.0, min(1.0, stance_prior))

    def to_dict(self):
        return {"agent_type": int(self.agent_type),
                "group_type": int(self.group_type),
                "nickname": self.nickname,
                "role_desc": self.role_desc,
                "stance_prior": self.stance_prior}

    @classmethod
    def from_dict(cls, d):
        return cls(agent_type=AgentType(d.get("agent_type", 0)),
                   group_type=GroupType(d.get("group_type", 1)),
                   nickname=str(d.get("nickname", "")),
                   role_desc=str(d.get("role_desc", "")),
                   stance_prior=float(d.get("stance_prior", 0)))


class PsychologyBelief:
    """心理信念"""
    def __init__(self, personality=None, risk_aversion=0.5):
        self.personality = personality or Personality()
        self.risk_aversion = max(0.0, min(1.0, risk_aversion))

    def to_dict(self):
        return {"personality": self.personality.to_dict(),
                "risk_aversion": self.risk_aversion}

    @classmethod
    def from_dict(cls, d):
        return cls(personality=Personality.from_dict(d.get("personality", {})),
                   risk_aversion=float(d.get("risk_aversion", 0.5)))


class OpinionBelief:
    """观点信念（按话题组织，v2：event_id → topic_id）"""
    def __init__(self, topic_id="", opinion_value=0.0, confidence=0.5):
        self.topic_id = topic_id
        self.opinion_value = max(-1.0, min(1.0, opinion_value))
        self.confidence = max(0.0, min(1.0, confidence))

    def to_dict(self):
        return {"topic_id": self.topic_id,
                "opinion_value": self.opinion_value,
                "confidence": self.confidence}

    @classmethod
    def from_dict(cls, d):
        return cls(topic_id=str(d.get("topic_id", "")),
                   opinion_value=float(d.get("opinion_value", 0)),
                   confidence=float(d.get("confidence", 0.5)))


class BeliefSystem:
    """四层信念系统"""
    def __init__(self, identity=None, psychology=None,
                 opinions=None, emotion=None):
        self.identity = identity or IdentityBelief()
        self.psychology = psychology or PsychologyBelief()
        self.opinions = opinions or {}  # Dict[str, OpinionBelief]
        self.emotion = emotion or EmotionState()

    def to_dict(self):
        return {"identity": self.identity.to_dict(),
                "psychology": self.psychology.to_dict(),
                "opinions": {k: v.to_dict() for k, v in self.opinions.items()},
                "emotion": self.emotion.to_dict()}


class SocialInfo:
    """微信消息信息（v2：大幅扩充字段）"""
    def __init__(self, source_id=0, source_nickname="", content="",
                 message_type=MessageType.ORIGINAL, timestamp=0,
                 is_mention=False, topic_id="",
                 distortion_level=0.0, original_content="",
                 negative_score=0.0, heat=0.0):
        self.source_id = source_id
        self.source_nickname = source_nickname
        self.content = content
        self.message_type = message_type
        self.timestamp = timestamp
        self.is_mention = is_mention
        self.topic_id = topic_id
        self.distortion_level = max(0.0, min(1.0, distortion_level))
        self.original_content = original_content
        self.negative_score = max(0.0, min(1.0, negative_score))
        self.heat = max(0.0, heat)

    def to_dict(self):
        return {"source_id": self.source_id,
                "source_nickname": self.source_nickname,
                "content": self.content,
                "message_type": self.message_type,
                "timestamp": self.timestamp,
                "is_mention": self.is_mention,
                "topic_id": self.topic_id,
                "distortion_level": self.distortion_level,
                "original_content": self.original_content,
                "negative_score": self.negative_score,
                "heat": self.heat}

    @classmethod
    def from_dict(cls, d):
        return cls(source_id=int(d.get("source_id", 0)),
                   source_nickname=str(d.get("source_nickname", "")),
                   content=str(d.get("content", "")),
                   message_type=str(d.get("message_type", MessageType.ORIGINAL)),
                   timestamp=int(d.get("timestamp", 0)),
                   is_mention=bool(d.get("is_mention", False)),
                   topic_id=str(d.get("topic_id", "")),
                   distortion_level=float(d.get("distortion_level", 0)),
                   original_content=str(d.get("original_content", "")),
                   negative_score=float(d.get("negative_score", 0)),
                   heat=float(d.get("heat", 0)))


class Perception:
    """
    感知对象（v2：群聊场景）
    B 模块仅读取，权威状态由 A 模块维护。
    """
    def __init__(self, group_id="", group_type=GroupType.CLASS, beta=0.0,
                 recent_messages=None, mentions=None, tick=0,
                 topic_heat=None, topic_negative=None):
        self.group_id = group_id
        self.group_type = group_type
        self.beta = beta
        self.recent_messages = recent_messages or []
        self.mentions = mentions or []
        self.tick = tick
        self.topic_heat = topic_heat or {}
        self.topic_negative = topic_negative or {}


class MemoryRecord:
    """记忆记录"""
    def __init__(self, tick=0, info=None, relevance=0.5):
        self.tick = tick
        self.info = info or SocialInfo()
        self.relevance = max(0.0, min(1.0, relevance))

    def to_dict(self):
        return {"tick": self.tick, "info": self.info.to_dict(),
                "relevance": self.relevance}


class Desire:
    """
    欲望（BDI 体系）
    B 模块 BDI 推理的中间产物，E 模块仅需知道其存在。
    """
    def __init__(self, goal_type="", priority=0.0,
                 topic_id="", target_id=None):
        self.goal_type = goal_type      # reply / discuss / share / clarify / intervene / silent
        self.priority = max(0.0, min(1.0, priority))
        self.topic_id = topic_id
        self.target_id = target_id


class Intention:
    """
    意图（BDI 体系）
    B 模块 BDI 推理的中间产物，E 模块仅需知道其存在。
    """
    def __init__(self, action_type=ActionType.SILENT, content_plan="",
                 topic_id="", target_id=None):
        self.action_type = action_type
        self.content_plan = content_plan
        self.topic_id = topic_id
        self.target_id = target_id


class ActionRecord:
    """
    行动记录（v2：ActionType + MessageType 双体系）
    - action_type: SEND_MESSAGE / REPLY / FORWARD / SILENT
    - message_type: original / forward / paraphrase / exaggerate / clarification
    """
    def __init__(self, agent_id=0, action_type=ActionType.SILENT, content="",
                 target_id=None, tick=0, topic_id="",
                 distortion_level=0.0,
                 message_type=MessageType.ORIGINAL,
                 negative_score=0.0, heat=0.0):
        self.agent_id = agent_id
        self.action_type = action_type
        self.content = content
        self.target_id = target_id
        self.tick = tick
        self.topic_id = topic_id
        self.distortion_level = max(0.0, min(1.0, distortion_level))
        self.message_type = message_type
        self.negative_score = max(0.0, min(1.0, negative_score))
        self.heat = max(0.0, heat)

    def to_dict(self):
        return {"agent_id": self.agent_id,
                "action_type": int(self.action_type),
                "content": self.content,
                "target_id": self.target_id,
                "tick": self.tick,
                "topic_id": self.topic_id,
                "distortion_level": self.distortion_level,
                "message_type": self.message_type,
                "negative_score": self.negative_score,
                "heat": self.heat}

    @classmethod
    def from_dict(cls, d):
        return cls(agent_id=int(d.get("agent_id", 0)),
                   action_type=ActionType(d.get("action_type", 3)),
                   content=str(d.get("content", "")),
                   target_id=d.get("target_id"),
                   tick=int(d.get("tick", 0)),
                   topic_id=str(d.get("topic_id", "")),
                   distortion_level=float(d.get("distortion_level", 0)),
                   message_type=str(d.get("message_type", MessageType.ORIGINAL)),
                   negative_score=float(d.get("negative_score", 0)),
                   heat=float(d.get("heat", 0)))


class SimConfig:
    """仿真配置（v2：支持群类型配置）"""
    def __init__(self, n_agents=50, agent_type_ratio=None,
                 group_type_ratio=None,
                 network_type="small_world", network_params=None,
                 n_steps=100, topics=None,
                 alpha=0.15, theta=0.7,
                 hawkes_params=None, llm_config=None,
                 random_seed=42):
        self.n_agents = n_agents
        self.agent_type_ratio = agent_type_ratio or {
            "ORDINARY": 0.7, "ACTIVE": 0.15,
            "RATIONAL": 0.1, "CONTROLLER": 0.05}
        self.group_type_ratio = group_type_ratio or {
            "DORM": 0.25, "CLASS": 0.35,
            "MAJOR": 0.25, "CAMPUS": 0.15}
        self.network_type = network_type
        self.network_params = network_params or {}
        self.n_steps = n_steps
        self.topics = topics or ["general"]
        self.alpha = alpha        # 自然衰减率 α
        self.theta = theta        # 干预触发阈值 θ
        self.hawkes_params = hawkes_params or {}
        self.llm_config = llm_config or {}
        self.random_seed = random_seed

    def to_dict(self):
        return {"n_agents": self.n_agents,
                "agent_type_ratio": self.agent_type_ratio,
                "group_type_ratio": self.group_type_ratio,
                "network_type": self.network_type,
                "network_params": self.network_params,
                "n_steps": self.n_steps,
                "topics": self.topics,
                "alpha": self.alpha,
                "theta": self.theta,
                "hawkes_params": self.hawkes_params,
                "llm_config": self.llm_config,
                "random_seed": self.random_seed}

    @classmethod
    def from_dict(cls, d):
        return cls(n_agents=int(d.get("n_agents", 50)),
                   agent_type_ratio=d.get("agent_type_ratio"),
                   group_type_ratio=d.get("group_type_ratio"),
                   network_type=str(d.get("network_type", "small_world")),
                   network_params=d.get("network_params"),
                   n_steps=int(d.get("n_steps", 100)),
                   topics=d.get("topics"),
                   alpha=float(d.get("alpha", 0.15)),
                   theta=float(d.get("theta", 0.7)),
                   hawkes_params=d.get("hawkes_params"),
                   llm_config=d.get("llm_config"),
                   random_seed=int(d.get("random_seed", 42)))

