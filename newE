# #34 save_simulation_results
# ════════════════════════════════════════════
_FLOAT_TO_INT16 = 32767
_FLOAT_TO_UINT16 = 65535
# 指标列 → 值域映射
_M11 = {"avg_opinion", "polarization", "emotional_contagion", "topic_heat"}
_M01 = {"participation_rate", "negative_score", "distortion_level",
        "confidence", "arousal"}


def _encode(col_name, value):
    if col_name in _M11:
        return int(round(np.clip(value, -1, 1) * _FLOAT_TO_INT16))
    if col_name in _M01:
        return int(round(np.clip(value, 0, 1) * _FLOAT_TO_UINT16))
    return value


def save_simulation_results(data: pd.DataFrame, path: str, fmt="csv") -> str:
    """
    保存仿真结果（v2：新增 topic_heat、negative_score 等列编码）。

    16bit 编码规则：
      [-1, 1] → int16  (×32767)
      [0, 1]  → uint16  (×65535)
    """
    fmt = fmt.lower()
    if fmt not in ("csv", "json"):
        raise ValueError(f"不支持格式: {fmt}")
    out = data.copy()
    for col in out.columns:
        if col in _M11 or col in _M01:
            out[col] = out[col].apply(lambda v: _encode(col, v))
    out_path = Path(path).with_suffix(f".{fmt}")
    out_path.parent.mkdir(parents=True, exist_ok=True)
    if fmt == "csv":
        out.to_csv(out_path, index=False, encoding="utf-8")
    else:
        out.to_json(out_path, orient="records", force_ascii=False, indent=2)
    return str(out_path.resolve())


