# #31 setup_llm_client
# ════════════════════════════════════════════
class LLMClient:
    def __init__(self, config: Dict[str, Any]):
        self.config = config
        self._client = None
        self._model = config.get("model", "gpt-3.5-turbo")
        self._base_url = config.get("base_url", "")
        self._api_key = config.get("api_key", "")
        self._temperature = config.get("temperature", 0.7)
        self._max_tokens = config.get("max_tokens", 1024)
        provider = config.get("provider", "openai")
        if provider in ("openai", "openai_compatible"):
            try:
                from openai import OpenAI
                self._client = OpenAI(api_key=self._api_key,
                                      base_url=self._base_url or None)
            except ImportError:
                _LOG.warning("openai 未安装, Mock 模式")

    def chat(self, prompt: str) -> str:
        """调用 LLM，返回 JSON 字符串。"""
        if self._client is None:
            # Mock: 默认沉默。调 parse_llm_response 会兜底为 SILENT
            return ('{"action_type":"SILENT","content":"","topic_id":"","'
                    '"message_type":"original","target_id":null}')
        try:
            resp = self._client.chat.completions.create(
                model=self._model,
                messages=[{"role": "user", "content": prompt}],
                temperature=self._temperature, max_tokens=self._max_tokens)
            return resp.choices[0].message.content or ""
        except Exception as e:
            _LOG.error("LLM 失败: %s", e)
            return ('{"action_type":"SILENT","content":"","topic_id":"",'
                    '"message_type":"original","target_id":null}')


def setup_llm_client(llm_config: Dict[str, Any]) -> LLMClient:
    """创建 LLM 客户端, 暴露 chat(prompt: str) -> str。"""
    return LLMClient(llm_config)


